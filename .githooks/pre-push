#!/usr/bin/env bash
#
# Pre-push quality gate — INTERIM, while GitHub Actions is billing-locked and has
# never executed a single job.
#
# A quality check you must remember to run is not a gate. This makes bin/quality
# an accident-floor: you cannot push past a regression by forgetting.
#
# HONEST LIMIT: this guards against FORGETTING, not against INTENT. `--no-verify`
# bypasses it, and deliberately so — an interim stopgap should not be able to trap
# you. Treat a bypass as a recorded decision, not a routine.
#
# Removed automatically when Actions runs and `linter`/`tests` become required
# status checks; this then becomes fast feedback rather than the floor.
# See CLAUDE.md § Workflow for the exit trigger.
set -uo pipefail

# Nothing to gate on a branch delete (all-zero local sha).
z40=0000000000000000000000000000000000000000
gated=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
    [ "$local_sha" = "$z40" ] || gated=1
done
[ "$gated" = "1" ] || exit 0

repo_root="$(git rev-parse --show-toplevel)"
printf '\033[1mpre-push:\033[0m running bin/quality (Actions is billing-locked; local is the gate)\n'

if "$repo_root/bin/quality"; then
    exit 0
fi

printf '\n\033[31mpush blocked by the local quality gate.\033[0m\n'
printf 'Fix the failures above, or bypass deliberately: git push --no-verify\n'
exit 1
