#!/usr/bin/env bash
#
# Pre-push quality gate — the PERMANENT enforcement floor.
#
# GitHub Actions is intentionally disabled (billing not pursued), so there is no
# remote CI and no required status checks. This hook and bin/quality ARE the floor,
# by design — not a stopgap waiting for CI to come back.
#
# A quality check you must remember to run is not a gate. This makes bin/quality an
# accident-floor: you cannot push past a regression by forgetting.
#
# Pushing to `main` is a RELEASE and needs more: per-branch green is not
# merged-result green, so main additionally requires a passing release gate
# (bin/quality-promote) stamped with the exact commit being pushed.
#
# HONEST LIMIT: this guards against FORGETTING, not INTENT. `--no-verify` bypasses
# it, deliberately — a floor that can trap you is worse than one you can step over
# on purpose. Treat a bypass as a recorded decision, never a routine.
#
# See CLAUDE.md § Workflow for what this floor does and does not prove.
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel)"
z40=0000000000000000000000000000000000000000

# git feeds the ref list on stdin ONCE — read it all up front, then inspect it as
# many times as needed. (Reading stdin twice silently yields nothing the second
# time, which would have made the main-branch check below a no-op.)
refs="$(cat)"

# Branch deletes carry an all-zero local sha and have nothing to verify.
gated=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
    [ -n "${local_sha:-}" ] || continue
    [ "$local_sha" = "$z40" ] || gated=1
done <<EOF
$refs
EOF
[ "$gated" = "1" ] || exit 0

# Release gate: a push to main must carry a stamp matching that exact commit.
while read -r _local_ref local_sha remote_ref _remote_sha; do
    [ -n "${remote_ref:-}" ] || continue
    [ "$local_sha" = "$z40" ] && continue
    case "$remote_ref" in
        refs/heads/main)
            stamp="$repo_root/.quality-promote-ok"
            if [ ! -f "$stamp" ] || [ "$(cat "$stamp" 2>/dev/null)" != "$local_sha" ]; then
                printf '\033[31mpush to main blocked:\033[0m no release-gate pass for %s\n' "${local_sha:0:8}"
                printf 'Verify staging first (verify-then-promote):\n'
                printf '  git checkout staging && bin/quality-promote\n'
                printf 'then merge staging into main and push. (Bypass: --no-verify, recorded as intent.)\n'
                exit 1
            fi
            printf '\033[32mpre-push:\033[0m release gate verified for %s\n' "${local_sha:0:8}"
            ;;
    esac
done <<EOF
$refs
EOF

printf '\033[1mpre-push:\033[0m running bin/quality (local is the enforcement floor)\n'

if "$repo_root/bin/quality"; then
    exit 0
fi

printf '\n\033[31mpush blocked by the local quality gate.\033[0m\n'
printf 'Fix the failures above, or bypass deliberately: git push --no-verify\n'
exit 1
